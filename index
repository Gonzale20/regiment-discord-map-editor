<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Regiment War Room | Gogland AO</title>

  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.css" />
  <link href="https://fonts.googleapis.com/css2?family=Quantico:wght@700&family=Saira+Condensed:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

  <style>
    :root {
      --mil-green: #1a3a1f;
      --mil-gold: #c6a84c;
      --mil-red: #8b2e2e;
      --mil-blue: #2e5b8b;
      --dark: #0a1a0d;
    }

    body, html { margin: 0; padding: 0; width: 100%; height: 100%; background: var(--dark); font-family: 'Saira Condensed', sans-serif; overflow: hidden; color: #e0e0e0; }
    
    /* Header & Branding */
    .topbar {
      height: 60px; background: var(--mil-green); border-bottom: 2px solid var(--mil-gold);
      display: flex; align-items: center; justify-content: space-between; padding: 0 20px; z-index: 2000; position: relative;
    }
    .logo-area { display: flex; align-items: center; gap: 15px; }
    .logo-placeholder { width: 40px; height: 40px; background: var(--mil-gold); border-radius: 4px; display: flex; align-items: center; justify-content: center; color: var(--dark); font-weight: bold; }
    .title-area h1 { font-family: 'Quantico', sans-serif; font-size: 1.2rem; margin: 0; letter-spacing: 2px; color: var(--mil-gold); }

    /* Layout */
    .main-container { display: flex; height: calc(100vh - 60px); width: 100%; }
    
    /* Sidebar Tools */
    .sidebar { width: 250px; background: rgba(26, 58, 31, 0.9); border-right: 1px solid var(--mil-gold); padding: 15px; overflow-y: auto; }
    .sidebar h3 { font-family: 'Quantico', sans-serif; font-size: 14px; color: var(--mil-gold); border-bottom: 1px solid var(--mil-gold); padding-bottom: 5px; margin-bottom: 15px; text-transform: uppercase; }
    
    .symbol-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 20px; }
    .symbol-btn { background: rgba(0,0,0,0.3); border: 1px solid #444; color: white; padding: 10px; cursor: pointer; text-align: center; transition: 0.2s; font-size: 12px; }
    .symbol-btn:hover { border-color: var(--mil-gold); background: rgba(198, 168, 76, 0.1); }
    .symbol-btn i { display: block; font-size: 1.5rem; margin-bottom: 5px; }

    /* Map Area */
    #map { flex-grow: 1; background: #050d06; cursor: crosshair; }

    /* UI Overlays */
    .coords-display {
      position: absolute; bottom: 20px; right: 20px;
      background: rgba(10, 26, 13, 0.9); border: 1px solid var(--mil-gold);
      color: var(--mil-gold); padding: 10px; font-family: 'Quantico', monospace; z-index: 1000;
    }
  </style>
</head>
<body>

  <header class="topbar">
    <div class="logo-area">
      <div class="logo-placeholder">TR</div>
      <div class="title-area">
        <h1>REGIMENT COMMAND CENTER</h1>
        <small style="color: #888;">AO: GOGLAND, ARMA REFORGER</small>
      </div>
    </div>
    <div class="status-fx">
      <button onclick="clearMap()" style="background:var(--mil-red); border:none; color:white; padding:8px 15px; font-family:'Quantico'; cursor:pointer;">ABORT MISSION</button>
    </div>
  </header>

  <div class="main-container">
    <aside class="sidebar">
      <h3>NATO Unit Symbols</h3>
      <div class="symbol-grid">
        <div class="symbol-btn" onclick="addNatoSymbol('infantry', 'blue')"><i class="fas fa-rectangle-xmark" style="color:var(--mil-blue)"></i>Infantry</div>
        <div class="symbol-btn" onclick="addNatoSymbol('armor', 'blue')"><i class="fas fa-circle-dot" style="color:var(--mil-blue)"></i>Armor</div>
        <div class="symbol-btn" onclick="addNatoSymbol('infantry', 'red')"><i class="fas fa-rectangle-xmark" style="color:var(--mil-red)"></i>Hostile Inf</div>
        <div class="symbol-btn" onclick="addNatoSymbol('armor', 'red')"><i class="fas fa-circle-dot" style="color:var(--mil-red)"></i>Hostile Arm</div>
      </div>

      <h3>Map Overlays</h3>
      <div class="symbol-grid">
        <div class="symbol-btn" onclick="map.setZoom(0)">Reset View</div>
        <div class="symbol-btn" onclick="saveOp()">Save Op</div>
      </div>
      
      <p style="font-size:11px; opacity: 0.6;">Select a tool above, then click the map to deploy assets to the AO.</p>
    </aside>

    <div id="map"></div>
    <div class="coords-display" id="coords">GRID: 0000 / 0000</div>
  </div>

  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet.draw/1.0.4/leaflet.draw.js"></script>

  <script>
    // 1. SETUP MAP FOR GOGLAND
    // Using Simple CRS for game-grid accuracy
    const map = L.map('map', {
        crs: L.CRS.Simple,
        minZoom: -2,
        maxZoom: 3,
        zoomControl: false
    });

    L.control.zoom({ position: 'topright' }).addTo(map);

    // Gogland Image Overlay (Replace with your actual hosted image URL)
    const goglandBounds = [[0, 0], [1000, 1000]];
    const gogland = L.imageOverlay('https://api.armasites.com/maps/gogland/topographic.jpg', goglandBounds).addTo(map);
    map.fitBounds(goglandBounds);

    const drawnItems = new L.FeatureGroup();
    map.addLayer(drawnItems);

    // 2. NATO SYMBOL GENERATOR
    function addNatoSymbol(type, side) {
        const color = (side === 'blue') ? '#2e5b8b' : '#8b2e2e';
        let svg = '';

        if(type === 'infantry') {
          svg = `<svg width="40" height="25"><rect width="40" height="25" fill="rgba(0,0,0,0.4)" stroke="${color}" stroke-width="3"/><line x1="0" y1="0" x2="40" y2="25" stroke="${color}"/><line x1="40" y1="0" x2="0" y2="25" stroke="${color}"/></svg>`;
        } else {
          svg = `<svg width="40" height="25"><rect width="40" height="25" fill="rgba(0,0,0,0.4)" stroke="${color}" stroke-width="3"/><ellipse cx="20" cy="12.5" rx="15" ry="8" fill="none" stroke="${color}" stroke-width="2"/></svg>`;
        }

        const icon = L.divIcon({
            html: svg,
            className: 'nato-icon',
            iconSize: [40, 25]
        });

        const marker = L.marker(map.getCenter(), {icon: icon, draggable: true}).addTo(drawnItems);
        marker.bindPopup(`<b>${side.toUpperCase()} ${type.toUpperCase()}</b><br>Right click to remove.`);
        
        marker.on('contextmenu', function() {
            drawnItems.removeLayer(marker);
        });
    }

    // 3. TACTICAL DRAWING
    const drawControl = new L.Control.Draw({
        edit: { featureGroup: drawnItems },
        draw: {
            circle: false,
            polyline: { shapeOptions: { color: 'var(--mil-gold)', weight: 3 } },
            polygon: { shapeOptions: { color: 'var(--mil-gold)', fillOpacity: 0.2 } },
            marker: false
        }
    });
    map.addControl(drawControl);

    map.on(L.Draw.Event.CREATED, (e) => drawnItems.addLayer(e.layer));

    // 4. COORDINATE TRACKING (Arma Style)
    map.on('mousemove', function(e) {
        let x = Math.round(e.latlng.lng).toString().padStart(4, '0');
        let y = Math.round(e.latlng.lat).toString().padStart(4, '0');
        document.getElementById('coords').innerHTML = `GRID: ${x} / ${y}`;
    });

    // 5. DATA MANAGEMENT
    function clearMap() { if(confirm("ABORT MISSION? This wipes all tactical data.")) drawnItems.clearLayers(); }
    function saveOp() {
        const data = JSON.stringify(drawnItems.toGeoJSON());
        localStorage.setItem('regiment_op_alpha', data);
        alert("Mission data synced to local command storage.");
    }
  </script>
</body>
</html>
